<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ritual DApps Board</title>
  
  <style>
    /* 1. Base Setup */
    html, body {
      margin: 0;
      padding: 0;
      min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background-color: #0b1313; /* Deep dark theme background color */
      color: #ffffff;
    }

    /* 2. The 30% Opacity Background Effect */
    body::before {
      content: "";
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      
      /* Pulls your raw image straight from your repo */
      background-image: url('https://raw.githubusercontent.com/Perorworld/RitualDapps-Board/main/ritualbg.jpg');
      background-position: center;
      background-repeat: no-repeat;
      background-size: contain; /* Keeps the logo proportions perfect */
      
      opacity: 0.30;          /* Locks the logo to exactly 30% opacity */
      z-index: -1;            /* Pushes it safely behind your text and elements */
      pointer-events: none;   /* Ghost layer: clicks pass right through to elements below */
      
      /* Optional: Blends the solid green outer square into your dark background color */
      mix-blend-mode: screen; 
    }

    /* 3. Layout Content Container */
    .content-wrapper {
      position: relative;
      z-index: 10; /* Lifts content layer safely over the background logo */
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem;
    }

    h1 {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
      font-weight: 700;
    }

    p {
      color: #94a3b8;
    }
  </style>
</head>
<body>

  <!-- All your website content goes inside this wrapper -->
  <div class="content-wrapper">
    <header>
      <h1>Ritual DApps Board</h1>
      <p>The background logo is fixed, centered, and set to 30% opacity.</p>
    </header>
    
    <main>
      <!-- Your DApp components, tables, or boards go here -->
    </main>
  </div>

</body>
</html>
